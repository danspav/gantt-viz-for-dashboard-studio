{
  "name": "gantt_viz_for_dashboard_studio",
  "version": "0.1.0",
  "description": "A custom visualization for Splunk Dashboard Studio",
  "author": "Daniel Spavin",
  "type": "module",
  "scripts": {
    "build": "node build.mjs --entry=visualization.jsx",
    "build:prod": "NODE_ENV=production node build.mjs --entry=visualization.jsx",
    "dev": "node build.mjs --entry=visualization.jsx --watch",
    "package": "node package.mjs"
  },
  "devDependencies": {
    "@splunk/dashboard-studio-extension": "^1.0.0",
    "@splunk/react-ui": "^5.11.1",
    "chalk": "^5.3.0",
    "esbuild": "^0.27.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "styled-components": "^5.3.10",
    "tar": "^7.4.3"
  },
  "dependencies": {
    "@babel/core": "^7.0.0-0",
    "@svar-ui/react-gantt": "^2.7.0",
    "@types/react": ">=16",
    "react-is": ">= 16.8.0",
    "typescript": ">=3.5.1"
  },
  "sideEffects": ["*.css","@svar-ui/react-gantt/all.css"]
}